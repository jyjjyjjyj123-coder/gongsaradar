# 공사인프라 백엔드 환경변수 샘플
# - 실제 .env는 절대 커밋하지 마세요 (git ls-files .env 로 확인)
# - 테스트 단계: 운영 키(live_*) 사용 금지, 공식 테스트 키만 사용

# ── 서버 설정
PORT=3001
JWT_SECRET=change-me-to-long-random-string

# ── 관리자 계정 (최초 기동 시 자동 생성)
ADMIN_EMAIL=admin@gongsaradar.com
ADMIN_PASSWORD=change-me

# ── 프론트엔드 URL (결제 리다이렉트용 - 토스가 여기로 돌려보냄)
FRONTEND_URL=http://localhost:8088
# 운영: https://gongsaradar-production.up.railway.app

# ── 토스페이먼츠 빌링결제 (정기결제)
# 공식 테스트 키: https://docs.tosspayments.com/reference/using-api/authorization
# 예시 형식 (실제 값은 본인 토스 상점 가입 후 확인):
TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TOSS_MODE=test
# 웹훅 HMAC 서명 검증 시크릿 (토스 상점관리자 페이지에서 발급)
TOSS_WEBHOOK_SECRET=

# billingKey AES-256-GCM 암호화 키 (미지정 시 JWT_SECRET 사용)
TOSS_BILLING_ENC_KEY=

# ── 외부 API
KISCON_API_KEY=your_kiscon_key
ARCH_API_KEY=your_arch_key

# ── 이메일 알림 (결제 실패 시 사용자 안내용 - 선택)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gongsainfra.com

# ── Railway 배포 시 추가 환경변수 (Railway Variables 탭)
# RAILWAY_VOLUME_MOUNT_PATH 은 Railway가 자동 주입
